# .gitignore 内容
__pycache__/
*.pyc
.env
.DS_Store
.vscode/
.idea/
venv/

# 本地仿真存档与 AI 报告（体积可能较大，不提交）
saved_runs/*
!saved_runs/.gitkeep
saved_ai_analyses/*
!saved_ai_analyses/.gitkeep

# 本仓库不纳入自动化测试目录（若本地自建可忽略）
tests/

# 本地工具 / 实验产物（含本机路径或大文件时不提交）
.claude/
experiment_results/

# 论文撰写、作图与本地文档（仅本地保留，不提交）
.cursor/
docs/
experiments/
extra_pairs.tsv
remaining_paras.txt
replacements.json
test_replacements.json
thesis/
